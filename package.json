{
  "name": "conta-azul-yoga-subgraph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'tests/e2e/**'",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:auth-e2e": "vitest run --config vitest.e2e.auth.config.ts",
    "print:schema": "tsx scripts/print-schema.ts",
    "generate-types": "openapi-typescript openapi/conta-azul.yaml -o src/conta-azul/schema.d.ts"
  },
  "dependencies": {
    "@apollo/subgraph": "^2.14.1",
    "graphql": "^16.9.0",
    "graphql-ws": "^6.0.6",
    "graphql-yoga": "^5.10.4",
    "ioredis": "^5.3.0",
    "jose": "^6.2.3",
    "mongodb": "^6.8.0",
    "openapi-fetch": "^0.14.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.0",
    "openapi-typescript": "^7.0.0",
    "testcontainers": "^10.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
