#!/bin/bash
# Runs on CI after yoga boots; SSH to droplet to register avcd_edge alias.
set -euo pipefail

HOST="${KAMAL_HOST:-}"
USER="${KAMAL_SSH_USER:-deploy}"
ALIAS="avcd-conta-azul-yoga-subgraph-web"
CONTAINER="${KAMAL_CONTAINER_NAME:-}"

[ -n "$HOST" ] || exit 0

ssh -o BatchMode=yes -o ConnectTimeout=15 "${USER}@${HOST}" \
  "ALIAS='${ALIAS}' CONTAINER='${CONTAINER}' bash -s" <<'REMOTE'
set -euo pipefail

if [ -z "${CONTAINER:-}" ]; then
  CONTAINER="$(docker ps -q --filter 'name=avcd-conta-azul-yoga-subgraph-web' | head -1)"
fi

[ -n "$CONTAINER" ] || exit 0

if docker inspect "$CONTAINER" --format '{{range .NetworkSettings.Networks.avcd_edge.Aliases}}{{println .}}{{end}}' 2>/dev/null | grep -qx "$ALIAS"; then
  echo "✓ $ALIAS already registered on avcd_edge"
  exit 0
fi

docker network disconnect avcd_edge "$CONTAINER" 2>/dev/null || true
docker network connect --alias "$ALIAS" avcd_edge "$CONTAINER"
echo "✓ Connected $CONTAINER to avcd_edge as $ALIAS"
REMOTE
