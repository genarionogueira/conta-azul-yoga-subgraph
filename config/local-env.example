# Local dev secrets — copy to .env.local (gitignored).
#
#   cp config/local-env.example .env.local
#   cp compose.override.local.example.yaml compose.override.local.yaml
#
# Infisical deploy sync: make bootstrap-deploy-secrets → .env.development

CONTA_AZUL_CLIENT_ID=
CONTA_AZUL_CLIENT_SECRET=

# Optional — omit to use compose Redis/Mongo services
# MONGO_LOCAL_PORT=27018
# WORKER_PORT=8010
# JWT_SECRET=
# CONTA_AZUL_SERVICE_JWT=   # HS256 JWT with sub=avcd-worker for bundled worker → yoga GraphQL
