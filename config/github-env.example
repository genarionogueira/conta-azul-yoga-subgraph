# GitHub Actions development environment — copy to config/github-env.local (gitignored).
#
# Fill values, then: make set-github-env
#
# Infisical project: avcd-conta-azul-yoga-subgraph
# UI: https://secrets.avcd.ai/projects/secret-management/<INFISICAL_PROJECT_ID>/secrets/dev

GITHUB_REPO=Avocado-Technology/conta-azul-yoga-subgraph

# Infisical (Settings → Machine Identities → conta-azul-yoga-subgraph-ci)
INFISICAL_PROJECT_ID=85a92fa7-85df-4343-bcbd-9ddd88ae656d
INFISICAL_OIDC_IDENTITY_ID=
INFISICAL_INFRA_PROJECT_ID=db036f0e-7452-4e17-9573-e5471b45d65f
INFISICAL_API_URL=https://secrets.avcd.ai/api
INFISICAL_OIDC_AUDIENCE=https://secrets.avcd.ai

# DigitalOcean dev droplet (pulumi stack output devDropletIp)
DO_DEPLOY_HOST=
DO_DEPLOY_USER=deploy
DO_PUBLIC_HOST=dev.avocado.tech
PUBLIC_HOST=dev.avocado.tech

# Container registry (GHCR — images pushed from CI with GITHUB_TOKEN)
GHCR_REGISTRY_URL=ghcr.io

# GitHub secrets (set separately — not via this script):
#   DO_DEPLOY_SSH_KEY
