# Secrets only — copy to .env and fill from the Conta Azul developer portal.
CONTA_AZUL_CLIENT_ID=
CONTA_AZUL_CLIENT_SECRET=

# MongoDB cache (non-secret default for local dev)
MONGODB_URL=mongodb://localhost:27017/conta_azul

# Non-secret runtime config is in docker-compose.yml (URLs, redirect URI, scope, Redis, etc.).
# For web-dash OAuth callback, override redirect URI in .env:
# CONTA_AZUL_REDIRECT_URI=http://localhost:3001/auth/conta-azul/callback
# Start stack: make dev → GraphiQL at http://localhost:4000/graphql
